{
  "package_id": "com.ethanchou.ethan-hud",
  "edition": "202601",
  "name": "Ethan HUD",
  "version": "0.1.0",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.12",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Connect to aggregator service for real-time dashboard data",
      "whitelist": [
        "ws://localhost:9500",
        "wss://localhost:9500",
        "ws://ethan-mac-mini.local:9500",
        "wss://ethan-mac-mini.local:9500",
        "ws://*.tail*.ts.net:9500",
        "wss://*.tail*.ts.net:9500"
      ]
    }
  ],
  "supported_languages": [
    "en",
    "zh-TW"
  ]
}
