{
  "name": "ethan-hud",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "pack": "npx @evenrealities/evenhub-cli pack",
    "qr": "npx @evenrealities/evenhub-cli qr --url http://$(hostname -I 2>/dev/null || ipconfig getifaddr en0):5173",
    "deploy:dev": "npm run dev",
    "dev:mock": "vite --open '/?mock=true'"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
